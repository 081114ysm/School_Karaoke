generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Reservation {
  id        Int      @id @default(autoincrement())
  name      String
  studentId String
  date      String
  createdAt DateTime @default(now())
}

model DisabledDate {
  id     Int     @id @default(autoincrement())
  date   String  @unique
  reason String?
}
